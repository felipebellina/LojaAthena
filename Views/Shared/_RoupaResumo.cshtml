@model RoupaModel

<div class="col-sm-4 col-md-4 col-lg-4">
    <p><img src="@Model.ImagemUrl" height="150px" width="150px" asp-append-version="true" /></p>
    <h3>@Model.Nome</h3>
    <h4>Preço : @Model.Preco.ToString("c")</h4>
    <p><a asp asp-controller="Roupa" asp-action="Details" asp-route-Id="@Model.Id">@Model.Nome</a></p>
    
    <p>@Model.Descricao</p>
    <div>
        <p class="button">
            <a class="btn btn-primary" id="cartButton" asp-controller="CarrinhoCompra" asp-action="AdicionarNoCarrinho"
            asp-route-Id="@Model.Id">
            Incluir no Carrinho
            </a>
        </p>
    </div>
</div>